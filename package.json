    "test": "vitest run"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.6",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
