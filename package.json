{
  "name": "xhood",
  "version": "0.1.0",
  "description": "xHood — talk to your Hermes agent from the terminal.",
  "type": "module",
  "bin": {
    "xhood": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "ARCHITECTURE.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xHoodAgent/cli.git"
  },
  "bugs": "https://github.com/xHoodAgent/cli/issues",
  "homepage": "https://github.com/xHoodAgent/cli#readme",
  "keywords": [
    "xhood",
